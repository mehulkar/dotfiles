{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "apiKeyHelper": "security find-generic-password -a \"$USER\" -s \"VERCEL_AI_GATEWAY_KEY\" -w",
  "env": {
    "ANTHROPIC_BASE_URL": "https://ai-gateway.vercel.sh"
  },
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(tar:*)",
      "Bash(xargs:*)",
      "Bash(datadog-query:*)",
      "Bash(datadog-query aggregate-logs:*)",
      "Bash(datadog-query query-metrics:*)",
      "Bash(datadog-query search-logs:*)",
      "Bash(datadog-query search-traces:*)",
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(git add:*)",
      "Bash(git log:*)",
      "Bash(git commit:*)",
      "Bash(git config:*)",
      "Bash(git push:*)",
      "Bash(git -C:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm check:*)",
      "Bash(pnpm install:*)",
      "Bash(turbo:*)"
    ]
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": true,
    "figma@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/mehulkar/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "verbose": false
}
