#!/usr/bin/env bash
#
# Keep track of env variables. Woohoo!
# Source this in whatever shell profile.
#
# Sourced from ~/.zshenv, so this runs before ~/.path adds /opt/homebrew/bin
# to PATH. Anything that calls a brew-installed binary below (fnm, starship,
# etc.) needs brew on PATH first — hence the brew shellenv at the top.
if [ -z "$HOMEBREW_PREFIX" ]; then
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

## I should probably figure out what this does
export ARCHFLAGS="-arch x86_64"

# Open gems in VSCode. Use `bundle open <gemname>`
export BUNDLER_EDITOR='code'
export EDITOR='vim'

# Pretty colors in terminal
export CLICOLOR=1
export LSCOLORS=gxBxhxDxfxhxhxhxhxcxcx
export LESS='-XF'
export HISTSIZE=9999999999     # increase hist size to a lot
export HISTTIMEFORMAT="%d/%m/%y %T "

eval "$(fnm env --use-on-cd)"

export PNPM_HOME="/Users/mehulkar/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"

# bun
## bun completions
[ -s "/Users/mehulkar/.bun/_bun" ] && source "/Users/mehulkar/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"

export TURBO_EXPERIMENTAL_UI=false
