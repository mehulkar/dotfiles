#!/usr/bin/env bash

function dpr() {
  echo "pushing to origin"
  git push origin -u
  echo "creating draft pr"
  gh pr create --fill-first -d "$@"
}

function mpr() {
  echo "pushing to origin"
  git push origin -u
  echo "creating pr"
  gh pr create --fill-first "$@"
}


function dev() {
  cd "$HOME/dev/$1" || exit
}

alias oss='dev oss'
alias dd='dev dotfiles'
alias dp='dev playground'

function webshare() {
  npx serve
}

## Shortcuts (guarded so missing tools don't break shell)
command -v bat &>/dev/null && alias cat=bat
command -v eza &>/dev/null && alias ls='eza -alHhF' || alias ls='ls -alHpGhF'
alias be='bundle exec'
alias rc='rustc'
alias vup='vim +PluginInstall +qall'
alias vim=nvim
alias tmux='TERM=screen-256color-bce tmux'
alias dc='docker-compose'
alias dm='docker-machine'
alias k=kubectl

# Git shortcuts
alias gp='git push origin'
alias gpf='git push --force-with-lease'
alias gc='git commit'
alias gaa='git add -A'
alias gpu='git push upstream'
alias gl='git log --format=fuller'

function gitstartover() {
  current=$(git cbr)
  git branch -m "$current-bak-$(date +%s)"
  git co main
  git checkout -b "$current"
}

# Github
alias myprs="gh pr list --search='org:vercel' --author '@me' --draft=false --json=url -q '.[].url'"
alias go="git open"

function failingchecks() {
  if [ -z $1 ]; then
    echo "Provide an arg"
    return
  fi

  REF=$(gh pr view $1 --json headRefOid | jq '.headRefOid' -r)
  echo "ref: $REF"
  gh api "repos/vercel/api/commits/$REF/check-runs" --jq ".check_runs[] | select(.conclusion != \"success\") | { name: .name, url: .html_url, conclusion: .conclusion }" | jq
}

